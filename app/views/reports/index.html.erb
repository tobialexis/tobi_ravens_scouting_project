<div class="reports-container">

  <h1>Player Reports</h1>

  <%= form_with url: reports_path,
                method: :get,
                local: true,
                class: "filter-form" do |form| %>

    <%= form.select :position,
                    ["", "QB", "RB", "WR", "TE", "OL", "DL", "LB", "CB", "S"],
                    selected: params[:position] %>

    <%= form.submit "Filter", class: "btn" %>

    <%= link_to "Clear",
                reports_path,
                class: "btn" %>

  <% end %>

  <%= link_to "➕ Create New Report",
              new_report_path,
              class: "btn" %>

  <br><br>

  <% if @reports.empty? %>

    <div class="card empty-state">
      <h2>🩷 No scouting reports available</h2>
      <p>Create a report to begin evaluating prospects.</p>
    </div>

  <% end %>

  <% @reports.each do |report| %>

    <div class="card">

      <div class="player-card-content">

        <div class="player-photo-wrapper">
          <% if report.photo.attached? %>
            <%= image_tag report.photo, class: "player-photo" %>
          <% else %>
            <div class="player-photo-placeholder">
              No Photo
            </div>
          <% end %>
        </div>

        <div class="player-card-details">

          <h2><%= report.player_name %></h2>

          <p>
            <strong>Position:</strong> <%= report.position %> |
            <strong>College:</strong> <%= report.college %> |
            <strong>40 Time:</strong> <%= report.speed_40 %>
          </p>

          <p>
            <strong>Comparison:</strong> <%= report.player_comparison %> |
            <strong>Projection:</strong> <%= report.draft_projection %> |
            <strong>Grade:</strong> <%= report.grade %>
          </p>

          <div class="grade-badge <%= badge_class(report.grade) %>">
            <%= scout_grade_label(report.grade) %>
          </div>

          <br>

          <%= link_to "View Report",
                      report,
                      class: "btn" %>

        </div>

      </div>

    </div>

  <% end %>

</div>